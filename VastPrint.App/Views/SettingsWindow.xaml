<Window x:Class="VastPrint.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        mc:Ignorable="d"
        Title="设置"
        Width="760"
        Height="560"
        MinWidth="680"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TabControl>
            <TabItem Header="文件筛选">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="文件导入规则" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="勾选哪些类型，文件夹扫描时只会加入这些扩展名。" />
                        <CheckBox Margin="0,14,0,0"
                                  Content="递归扫描子目录"
                                  IsChecked="{Binding IncludeSubDirectories}" />
                    </StackPanel>

                    <StackPanel Grid.Row="2"
                                Orientation="Horizontal">
                        <Button Width="108"
                                Height="36"
                                Margin="0,0,8,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding SelectAllExtensionsCommand}"
                                Content="全选" />
                        <Button Width="108"
                                Height="36"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ClearAllExtensionsCommand}"
                                Content="取消全选" />
                    </StackPanel>

                    <Border Grid.Row="4"
                            Padding="12"
                            Background="#F8FAFC"
                            BorderBrush="{StaticResource PanelBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding ExtensionOptions}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <primitives:UniformGrid Columns="2" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Margin="0,0,0,12"
                                                  Content="{Binding DisplayText}"
                                                  IsChecked="{Binding IsEnabled}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="高级">
                <Grid Margin="16">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="队列策略" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   Text="这里控制批量打印时的容错行为。" />
                        <CheckBox Margin="0,16,0,0"
                                  Content="单个文件失败后继续后续文件"
                                  IsChecked="{Binding ContinueOnError}" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="108"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click"
                    Content="取消" />
            <Button Width="108"
                    Click="ConfirmButton_Click"
                    Content="保存" />
        </StackPanel>
    </Grid>
</Window>
