<Window x:Class="VastPrint.App.Views.PageSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="页面设置"
        Width="640"
        Height="600"
        MinWidth="560"
        MinHeight="520"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="16"
                        Margin="0,0,0,16"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="当前打印机" />
                        <TextBlock Margin="0,8,0,0"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Text="{Binding PrinterName}" />
                        <TextBlock Margin="0,6,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding CapabilitySummary}" />
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        Margin="0,0,0,16"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <StackPanel>
                        <TextBlock FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="纸张与版面" />
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{StaticResource MutedTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding NativePageSetupSummary}" />
                        <Button Width="180"
                                Margin="0,12,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding OpenSystemPageSetupCommand}"
                                Content="纸张和边距..." />
                    </StackPanel>
                </Border>

                <Border Padding="16"
                        Background="{StaticResource PanelBackgroundBrush}"
                        BorderBrush="{StaticResource PanelBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="12">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.ColumnSpan="2"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Text="打印方式" />

                        <TextBlock Grid.Row="2"
                                   VerticalAlignment="Center"
                                   Text="彩色 / 黑白" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  Height="36"
                                  ItemsSource="{Binding ColorModeOptions}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding ColorMode}" />

                        <TextBlock Grid.Row="4"
                                   VerticalAlignment="Center"
                                   Text="单面 / 双面" />
                        <ComboBox Grid.Row="4"
                                  Grid.Column="1"
                                  Height="36"
                                  ItemsSource="{Binding DuplexModeOptions}"
                                  DisplayMemberPath="Value"
                                  SelectedValuePath="Key"
                                  SelectedValue="{Binding DuplexMode}" />

                        <TextBlock Grid.Row="6"
                                   VerticalAlignment="Center"
                                   Text="彩色渲染" />
                        <StackPanel Grid.Row="6"
                                    Grid.Column="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Width="40"
                                        Margin="0,0,8,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DecreaseColorRenderDpiCommand}"
                                        Content="-" />
                                <Slider Grid.Column="1"
                                        Minimum="120"
                                        Maximum="300"
                                        TickFrequency="30"
                                        IsSnapToTickEnabled="True"
                                        Value="{Binding ColorRenderDpi}" />
                                <Button Grid.Column="2"
                                        Width="40"
                                        Margin="8,0,8,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding IncreaseColorRenderDpiCommand}"
                                        Content="+" />
                                <TextBlock Grid.Column="3"
                                           MinWidth="64"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"
                                           Text="{Binding ColorRenderDpiSummary}" />
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       TextWrapping="Wrap"
                                       Text="默认 180 DPI。数值越高越清晰，但发送到打印机的任务体积也会更大。" />
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="1"
                    Margin="0,16,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Width="108"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="CancelButton_Click"
                    Content="取消" />
            <Button Width="108"
                    Click="ConfirmButton_Click"
                    Content="保存" />
        </StackPanel>
    </Grid>
</Window>
